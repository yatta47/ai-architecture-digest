---
import { url, plainExcerpt } from '../lib/facets';
import { label } from '../lib/labels';
import type { CaseEntry } from '../lib/facets';

interface Props {
  entry: CaseEntry;
}
const { entry } = Astro.props;
const d = entry.data;
const excerpt = plainExcerpt(entry.body, 140);
const cloud = d.cloud[0] || 'none';
const thumbLabel = (d.cloud[0] || d.source_id || 'src').toUpperCase();
const metaBits = [d.source_name, ...d.cloud, label('industries', d.industry), d.company].filter(Boolean);
const isNew = Date.now() - new Date(d.published_at).getTime() < 14 * 864e5;
---

<a class="row" href={url(`cases/${entry.id}`)}>
  <div class={`thumb cloud-${cloud}`}>
    <span class="thumb-cloud">{thumbLabel}</span>
    <span class={`thumb-type type-${d.type}`}>{d.type}</span>
  </div>
  <div class="row-body">
    <h3 class="row-title">{d.title}</h3>
    <div class="row-meta">
      from: {metaBits.join(' · ')}
      {isNew && <span class="new">New!</span>}
      {d.ai_relevant === false && <span class="cov">概要のみ</span>}
    </div>
    {excerpt && <p class="row-excerpt">{excerpt}…</p>}
    <div class="chips">
      {d.patterns.map((x) => <span class="chip pat">{x}</span>)}
      {d.components.slice(0, 3).map((x) => <span class="chip comp">{x}</span>)}
    </div>
  </div>
</a>
