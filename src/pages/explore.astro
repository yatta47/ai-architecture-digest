---
import Base from '../layouts/Base.astro';
import { allCases, facetSummary, accessors, url } from '../lib/facets';
import { label as jaLabel } from '../lib/labels';

const entries = await allCases();
const groups = [
  { label: 'クラウド', key: 'cloud', route: 'cloud' },
  { label: 'パターン', key: 'patterns', route: 'patterns' },
  { label: '業界', key: 'industries', route: 'industries' },
  { label: '技術スタック', key: 'components', route: 'components' },
  { label: '企業', key: 'companies', route: 'companies' },
  { label: '成果', key: 'outcomes', route: 'outcomes' },
]
  .map((g) => ({ ...g, items: facetSummary(entries, accessors[g.key]) }))
  .filter((g) => g.items.length > 0);
---

<Base title="軸で探す">
  <h1 class="page">軸で探す</h1>
  <p class="count">クラウド・パターン・業界・技術スタック・企業・成果で引く。全{entries.length}件。</p>
  <div class="explore-grid">
    {groups.map((g) => (
      <div class="exp-group">
        <div class="exp-title">{g.label}</div>
        {g.items.map((it) => (
          <a class="exp-link" href={url(`${g.route}/${it.slug}`)}>
            <span>{jaLabel(g.key, it.label)}</span><span class="c">{it.count}</span>
          </a>
        ))}
      </div>
    ))}
  </div>
</Base>
