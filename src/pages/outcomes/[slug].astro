---
import Base from '../../layouts/Base.astro';
import CaseRow from '../../components/CaseRow.astro';
import { allCases, facetPaths, accessors } from '../../lib/facets';
import { label as jaLabel } from '../../lib/labels';

export async function getStaticPaths() {
  const entries = await allCases();
  return facetPaths(entries, accessors['outcomes']);
}
const { label, items } = Astro.props;
const ja = jaLabel('outcomes', label);
---

<Base title={`成果: ${ja}`}>
  <h1 class="page">成果: {ja}</h1>
  <p class="count">{items.length}件</p>
  <div class="feed-list">{items.map((e) => <CaseRow entry={e} />)}</div>
</Base>
